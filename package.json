{
  "name": "arbid",
  "version": "0.0.0",
  "description": "Deterministic code exploration primitives for Pi — tree-sitter + SQLite tools for finding callers, definitions, and file outlines",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "tree-sitter": "file:/home/johan/Projects/node-tree-sitter",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tree-sitter-javascript": "^0.25.0",
    "typebox": "^1.1.37",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "test": "npx tsx tests/test.ts",
